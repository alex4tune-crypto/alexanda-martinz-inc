{
  "framework": "vite",
  "src": "frontend-portal",
  "installCommand": "cd frontend-portal && npm install",
  "buildCommand": "cd frontend-portal && npm run build",
  "outputDirectory": "frontend-portal/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}